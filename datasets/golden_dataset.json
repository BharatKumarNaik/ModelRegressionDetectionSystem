  {
    "id": "TC_004",
    "category": "ranking",
    "difficulty": "medium",
    "sql_features": ["TOP", "GROUP BY", "ORDER BY"],
    "business_domain": "Customer",
    "question": "Who are the top five customers by total transaction amount?",
    "baseline": {
      "model": "gemini-2.5-flash",
      "prompt_version": "v1.0",
      "sql": "SELECT TOP 5 c.CustomerName, SUM(ct.TransactionAmount) AS Revenue FROM Sales.CustomerTransactions ct JOIN Sales.Customers c ON ct.CustomerID = c.CustomerID GROUP BY c.CustomerName ORDER BY Revenue DESC;"
    },
    "expected": {
    "columns": [
        "CustomerName",
        "Revenue"
    ],
    "rows": [
        [
            "Wingtip Toys (Head Office)",
            "97053.58"
