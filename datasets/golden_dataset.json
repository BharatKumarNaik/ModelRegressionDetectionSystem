  {
    "id": "TC_007",
    "category": "comparative_analysis",
    "difficulty": "medium",
    "sql_features": ["AVG", "GROUP BY", "JOIN"],
    "business_domain": "Sales",
    "question": "Compare the average transaction amount across customer categories.",
    "baseline": {
      "model": "gemini-2.5-flash",
      "prompt_version": "v1.0",
      "sql": "SELECT cc.CustomerCategoryName, AVG(ct.TransactionAmount) AS AverageTransaction FROM Sales.CustomerTransactions ct JOIN Sales.Customers c ON ct.CustomerID = c.CustomerID JOIN Sales.CustomerCategories cc ON c.CustomerCategoryID = cc.CustomerCategoryID GROUP BY cc.CustomerCategoryName;"
    },
    "expected": {
    "columns": [
