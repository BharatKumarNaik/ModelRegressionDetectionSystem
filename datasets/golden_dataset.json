            "56435.84"
        ],
        [
            "Kumar Naicker",
            "13212.12"
        ],
        [
            "Linh Dao",
            "6728.65"
        ],
        [
            "Rodrigo Figueiredo",
            "5975.40"
        ]
    ]
},
    "critical": true
