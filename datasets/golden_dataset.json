  {
    "id": "TC_010",
    "category": "advanced_business",
    "difficulty": "hard",
    "sql_features": ["ROW_NUMBER", "PARTITION BY", "JOIN"],
    "business_domain": "Sales",
    "question": "Identify the top three customers by revenue within each buying group.",
    "baseline": {
      "model": "gemini-2.5-flash",
      "prompt_version": "v1.0",
      "sql": "WITH CustomerRevenue AS (SELECT bg.BuyingGroupName, c.CustomerName, SUM(ct.TransactionAmount) AS Revenue FROM Sales.CustomerTransactions ct JOIN Sales.Customers c ON ct.CustomerID = c.CustomerID JOIN Sales.BuyingGroups bg ON c.BuyingGroupID = bg.BuyingGroupID GROUP BY bg.BuyingGroupName, c.CustomerName) SELECT BuyingGroupName, CustomerName, Revenue FROM (SELECT *, ROW_NUMBER() OVER(PARTITION BY BuyingGroupName ORDER BY Revenue DESC) AS rn FROM CustomerRevenue) t WHERE rn <= 3;"
    },
    "expected": {
    "columns": [
        "BuyingGroupName",
        "CustomerName",
        "Revenue"
    ],
    "rows": [
        [
            "Tailspin Toys",
            "Tailspin Toys (Head Office)",
            "56435.84"
        ],
        [
            "Wingtip Toys",
            "Wingtip Toys (Head Office)",
            "97053.58"
        ]
    ]
},
    "critical": true
  }
]